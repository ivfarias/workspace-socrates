{
  "id": "socrates",
  "commands": {
    "text": true,
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "github-copilot/claude-sonnet-4-6",
        "imageModel": "openai/gpt-4o"
      },
      "heartbeat": {
        "every": "5m",
        "model": "github-copilot/claude-haiku-4-5"
      }
    }
  },
  "messages": {
    "tts": {
      "summaryModel": "openai/gpt-4.1-mini"
    }
  },
  "subagents": {
    "defaults": {
      "maxSpawnDepth": 2,
      "runTimeoutSeconds": 1500,
      "archiveAfterMinutes": 60
    }
  },
  "tools": {
    "allow": [
      "all"
    ],
    "deny": [],
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": true
      }
    },
    "subagents": {
      "model": "github-copilot/claude-sonnet-4-6",
      "defaults": {
        "maxSpawnDepth": 2,
        "runTimeoutSeconds": 1500,
        "archiveAfterMinutes": 60
      }
    }
  }
}
