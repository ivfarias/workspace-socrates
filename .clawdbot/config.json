{
  "version": 1,
  "worktrees": {
    "root": ".worktrees",
    "installDependencies": true,
    "installCommand": "pnpm install --prefer-offline"
  },
  "limits": {
    "maxConcurrentAgents": 3,
    "maxConcurrentHeavyAgents": 1,
    "heavyTaskTypes": [
      "frontend-ui",
      "integration",
      "e2e",
      "build-heavy"
    ]
  },
  "retryPolicy": {
    "maxAttempts": 3,
    "cooldownSeconds": 90,
    "autoRespawnOnSessionExit": true,
    "autoRespawnOnCiFailure": true,
    "autoRespawnOnCriticalReview": true
  },
  "monitoring": {
    "intervalSeconds": 600
  },
  "doneCriteria": {
    "requiredChecks": [
      "prCreated",
      "ciPassed",
      "branchUpToDate",
      "codexReviewPassed",
      "claudeReviewPassed",
      "geminiReviewPassed"
    ],
    "noPrSpec": {
      "requireSessionExit": true
    }
  },
  "models": {
    "default": "claude-sonnet-4.6",
    "heartbeat": "claude-haiku-4.5",
    "subagents": "claude-sonnet-4.6",
    "profiles": {
      "backend-complex": "claude-sonnet-4.6",
      "backend-fast": "claude-sonnet-4.6",
      "frontend-ui": "claude-sonnet-4.6",
      "ux-design": "gemini-2.5-pro",
      "analysis": "claude-opus-4.6",
      "heartbeat": "claude-haiku-4.5"
    },
    "agentDefaults": {
      "codex": "claude-sonnet-4.6",
      "claude": "claude-sonnet-4.6",
      "gemini": "gemini-2.5-pro",
      "openclaw": "claude-sonnet-4.6"
    }
  }
}
